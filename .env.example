# Copie este arquivo para .env para uso local. Nunca versione o arquivo .env.
#
# Estas configurações ainda não são consumidas pela API legada. Elas definem o
# contrato de ambiente que será ligado ao serviço de inferência na Fase 2.
MEDTRACK_ENV=local
MEDTRACK_LOG_LEVEL=INFO
MEDTRACK_MODEL_URI=models/medtrack-yolo/v1.0.0/best.pt
MEDTRACK_MODEL_VERSION=v1.0.0
MEDTRACK_DEVICE=cpu
MEDTRACK_MAX_IMAGE_DIMENSION=1024
MEDTRACK_YOLO_CONFIDENCE=0.5
MEDTRACK_CORS_ORIGINS=
